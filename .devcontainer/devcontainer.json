// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Node.js & TypeScript",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Installs the OS-level shared libraries (libnss3, libatk-bridge2.0-0, libgtk-3-0, etc.)
	// headless Chrome needs to run at all — pa11y-ci and any local Lighthouse run (accessibility/
	// perf checks) depend on this. Deliberately does NOT install the `chromium` apt package
	// itself: in some sandboxed environments its crashpad self-test crashes with SIGTRAP on
	// launch (a ptrace restriction — --cap-add=SYS_PTRACE was tried and did not help). Puppeteer's
	// own downloaded "Chrome for Testing" build (already a transitive dependency via pa11y-ci)
	// works fine given just these libraries, so leave PUPPETEER_SKIP_DOWNLOAD /
	// PUPPETEER_EXECUTABLE_PATH unset and let `npm install`'s postinstall step fetch one
	// normally. See PLAN-BUILD.md §7.1 for the full story.
	"postCreateCommand": "sudo apt-get update && npx --yes playwright install-deps chromium",

	"customizations": {
		"vscode": {
			"extensions": [
				"Anthropic.claude-code"
			]
		}
	},

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
